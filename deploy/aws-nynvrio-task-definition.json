{
    "executionRoleArn": "arn:aws:iam::029569477348:role/github-actions-nynvrio",
    "containerDefinitions": [
        {
            "name": "nynvrio-backend",
            "image": "dkr.ecr.us-east-1.amazonaws.com/nynvrio-backend",
            "cpu": 0,
            "portMappings": [
                {
                    "name": "nynvrio-backend-80-tcp",
                    "containerPort": 80,
                    "hostPort": 80,
                    "protocol": "tcp",
                    "appProtocol": "http"
                }
            ],
            "essential": true,
            "environment": [],
            "environmentFiles": [],
            "mountPoints": [],
            "volumesFrom": [],
            "ulimits": [],
            "systemControls": []
        }
    ],
    "family": "nynvrio-task",
    "networkMode": "awsvpc",
    "volumes": [],
    "placementConstraints": [],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "1024",
    "memory": "2048",
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    },
    "tags": []
}