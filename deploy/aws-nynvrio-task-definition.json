{
    "executionRoleArn": "arn:aws:iam::029569477348:role/github-actions-nynvrio",
    "containerDefinitions": [
        {
            "name": "nynvrio-backend",
            "image": "dkr.ecr.us-east-1.amazonaws.com/nynvrio-backend",
            "cpu": 0,
            "portMappings": [
                {
                    "name": "nynvrio-backend-80-tcp",
                    "containerPort": 80,
                    "hostPort": 80,
                    "protocol": "tcp",
                    "appProtocol": "http"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "DEBUG",
                    "value": "{{ secrets.DEBUG }}"
                },
                {
                    "name": "DJANGO_SECRET_KEY",
                    "value": "{{ secrets.DJANGO_SECRET_KEY }}"
                },
                {
                    "name": "ALLOWED_HOSTS",
                    "value": "{{ secrets.ALLOWED_HOSTS }}"
                },
                {
                    "name": "DB_HOST",
                    "value": "{{ secrets.DB_HOST }}"
                },
                {
                    "name": "DB_PORT",
                    "value": "{{ secrets.DB_PORT }}"
                },
                {
                    "name": "DB_NAME",
                    "value": "{{ secrets.DB_NAME }}"
                },
                {
                    "name": "DB_USER",
                    "value": "{{ secrets.DB_USER }}"
                },
                {
                    "name": "DB_PASSWORD",
                    "value": "{{ secrets.DB_PASSWORD }}"
                }
            ],
            "environmentFiles": [],
            "mountPoints": [],
            "volumesFrom": [],
            "ulimits": [],
            "systemControls": []
        }
    ],
    "family": "nynvrio-task",
    "networkMode": "awsvpc",
    "volumes": [],
    "placementConstraints": [],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "1024",
    "memory": "2048",
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    },
    "tags": []
}